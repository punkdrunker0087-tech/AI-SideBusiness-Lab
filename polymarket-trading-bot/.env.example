# このファイルをコピーして .env を作り、実際の値を入れる。
# .env は絶対にコミットしないこと（.gitignore で除外済み）。

# Polygon上のウォレット秘密鍵（0x始まり）。注文執行に使う。
# 絶対に他人と共有しない。漏洩=資金の完全な喪失。
POLY_PRIVATE_KEY=

# derive-api-key で取得したAPI認証情報
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# 資金移動元のウォレットアドレス（proxy walletの場合は指定）
POLY_FUNDER_ADDRESS=

# CLOB APIのベースURL（通常は変更不要）
POLY_CLOB_HOST=https://clob.polymarket.com

# true にしない限り実発注は行われない（デフォルト: ドライラン）
LIVE_TRADING=false

# 1注文あたりの上限USD
MAX_ORDER_USD=10

# 1日あたりの損失上限USD（これを超えたら自動停止）
MAX_DAILY_LOSS_USD=50

# 監視対象市場を絞るキーワード（カンマ区切り、空なら全市場対象）
MARKET_KEYWORDS=

# ポーリング間隔（秒）
POLL_INTERVAL_SECONDS=60
